#!/bin/sh

# vpm - vomP Package Manager
# Uses Alpine Linux repositories (musl-compatible)

CONFIG_FILE="/etc/vpm.conf"
DB_DIR="/var/db/vpm"
CACHE_DIR="/var/cache/vpm"
INDEX_FILE="/var/cache/vpm/APKINDEX"
ARCH="x86_64"
ALPINE_VER="edge"
REPOS="main community"
MIN_EDGE_MUSL="1.2.5"
INSTALL_STACK="${INSTALL_STACK:-}"

# ---------------------------------------------------------------------------
# Mirrors
# ---------------------------------------------------------------------------

show_mirrors() {
    echo "Available mirrors:"
    echo "  global  - dl-cdn.alpinelinux.org (CDN, recommended)"
    echo "  ru      - mirror.yandex.ru"
    echo "  de      - ftp.halifax.rwth-aachen.de"
    echo "  us      - mirrors.edge.kernel.org"
    echo "  fr      - alpine.42.fr"
    echo "  jp      - ftp.jaist.ac.jp"
    echo "  nl      - nl.alpinelinux.org"
}

show_help() {
    echo "vpm - vomP Package Manager (Alpine-based)"
    echo ""
    echo "Usage:"
    echo "  vpm mirror <region>      - set mirror (ru/de/us/fr/jp/nl/global)"
    echo "  vpm mirror?              - show current mirror"
    echo "  vpm update               - sync package index"
    echo "  vpm search <pkg>         - search for package"
    echo "  vpm info <pkg>           - show package info"
    echo "  vpm install <pkg>        - install package with deps and post-install fixes"
    echo "  vpm remove <pkg>         - remove package"
    echo "  vpm list                 - list installed packages"
    echo "  vpm upgrade              - upgrade all installed packages"
    echo ""
    show_mirrors
    exit 1
}

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

get_mirror() {
    if [ -f "$CONFIG_FILE" ]; then
        cat "$CONFIG_FILE"
    else
        echo "https://dl-cdn.alpinelinux.org/alpine"
    fi
}

ensure_dirs() {
    mkdir -p "$DB_DIR" "$CACHE_DIR"
}

ensure_index() {
    if [ ! -f "$INDEX_FILE" ]; then
        echo "[ ! ] Package index not found. Run: vpm update"
        exit 1
    fi
}

pkg_field() {
    PKG="$1"
    FIELD="$2"
    awk -v pkg="$PKG" -v field="$FIELD" '
        /^$/ { found=0 }
        /^P:/ { if ($0 == "P:"pkg) found=1 }
        found && /^[A-Z]:/ { if (substr($0,1,2) == field":") { print substr($0,3); exit } }
    ' "$INDEX_FILE"
}

pkg_exists() {
    [ -n "$(pkg_field "$1" V)" ]
}

normalize_dep() {
    DEP="$1"
    DEP=${DEP#!}
    case "$DEP" in
        ""|cmd:*|so:*|pc:*|*.so.*|*.so) return 1 ;;
    esac
    DEP=${DEP%%[<>=~]*}
    case "$DEP" in
        ""|*:*) return 1 ;;
        *) printf '%s\n' "$DEP" ;;
    esac
}

version_ge() {
    [ "$(printf '%s\n%s\n' "$2" "$1" | sort -V | head -n 1)" = "$2" ]
}

musl_version() {
    for LOADER in /usr/lib/libc.so /lib/ld-musl-x86_64.so.1 /lib/libc.musl-x86_64.so.1; do
        [ -x "$LOADER" ] || [ -f "$LOADER" ] || continue
        "$LOADER" 2>&1 | awk '/Version / { sub(/^Version /, ""); sub(/-.*/, ""); print; exit }'
        return
    done
}

needs_edge_musl() {
    CUR=$(musl_version)
    [ -n "$CUR" ] || return 1
    version_ge "$CUR" "$MIN_EDGE_MUSL"
}

make_tmpdir() {
    mktemp -d "${TMPDIR:-/tmp}/vpm.XXXXXX"
}

download_pkg() {
    PKG="$1"
    VER="$2"
    APK_FILE="${PKG}-${VER}.apk"
    MIRROR=$(get_mirror)

    if [ -f "${CACHE_DIR}/${APK_FILE}" ]; then
        echo "[ . ] Using cached $APK_FILE"
        return 0
    fi

    for REPO in $REPOS; do
        URL="${MIRROR}/${ALPINE_VER}/${REPO}/${ARCH}/${APK_FILE}"
        echo "[ . ] Downloading $PKG-$VER from $REPO..."
        if curl -sSf -o "${CACHE_DIR}/${APK_FILE}" "$URL"; then
            return 0
        fi
    done

    rm -f "${CACHE_DIR}/${APK_FILE}"
    return 1
}

run_pkg_script() {
    SCRIPT="$1"
    PKG="$2"
    VER="$3"
    if [ -f "$SCRIPT" ]; then
        chmod +x "$SCRIPT" 2>/dev/null
        echo "[ . ] Running $(basename "$SCRIPT") for $PKG..."
        VPM_POST_INSTALL=1 /bin/sh "$SCRIPT" "$PKG" "$VER" || echo "[ ! ] $(basename "$SCRIPT") for $PKG failed, continuing"
    fi
}

extract_apk_payload() {
    APK_FILE="$1"
    WORKDIR="$2"
    DEST="$3"

    ( cd "$WORKDIR" && tar -xzf "$APK_FILE" 2>/dev/null )
    if [ -f "$WORKDIR/data.tar.gz" ]; then
        tar -xzf "$WORKDIR/data.tar.gz" -C "$DEST"
    else
        tar -xzf "$APK_FILE" -C "$DEST" --exclude='.PKGINFO' --exclude='.pre-install' --exclude='.post-install' 2>/dev/null
    fi
}

record_filelist() {
    APK_FILE="$1"
    WORKDIR="$2"
    PKG="$3"
    if [ -f "$WORKDIR/data.tar.gz" ]; then
        tar -tzf "$WORKDIR/data.tar.gz" | sed 's#^#/#' > "$DB_DIR/$PKG.files"
    else
        tar -tzf "$APK_FILE" | grep -v '^\.PKGINFO$' | grep -v '^\.pre-install$' | grep -v '^\.post-install$' | sed 's#^#/#' > "$DB_DIR/$PKG.files"
    fi
}

ensure_runtime_compat() {
    PKG="$1"
    [ "$ALPINE_VER" = "edge" ] || return 0
    [ "$PKG" = "musl" ] && return 0
    [ -f "$DB_DIR/musl" ] && return 0
    if ! needs_edge_musl; then
        CUR=$(musl_version)
        echo "[ ! ] System musl ${CUR:-unknown} is older than Alpine edge runtime ($MIN_EDGE_MUSL+)"
        echo "[ . ] Installing musl first to prevent instant segfaults..."
        cmd_install musl || {
            echo "[ ! ] Failed to install compatible musl; aborting $PKG"
            exit 1
        }
    fi
}

ensure_terminfo() {
    [ -d /usr/share/terminfo ] && [ -n "$(find /usr/share/terminfo -type f 2>/dev/null | head -n 1)" ] && return 0
    [ -f "$DB_DIR/ncurses-terminfo-base" ] && return 0
    if pkg_exists ncurses-terminfo-base; then
        echo "[ . ] Installing ncurses-terminfo-base for terminal programs..."
        cmd_install ncurses-terminfo-base || echo "[ ! ] Could not install ncurses-terminfo-base"
    fi
}

post_install_fixes() {
    PKG="$1"

    # Alpine packages expect these loader/libc names. Keep them sane after musl upgrades.
    if [ -f /lib/libc.musl-x86_64.so.1 ]; then
        ln -sf /lib/libc.musl-x86_64.so.1 /usr/lib/libc.so 2>/dev/null || true
    fi
    if [ -f /lib/ld-musl-x86_64.so.1 ] && [ ! -e /usr/lib/ld-musl-x86_64.so.1 ]; then
        ln -sf /lib/ld-musl-x86_64.so.1 /usr/lib/ld-musl-x86_64.so.1 2>/dev/null || true
    fi

    case "$PKG" in
        nano|fastfetch|htop|vim|neovim|ncurses|ncurses-terminfo*|terminfo*) ensure_terminfo ;;
    esac

    [ -x /sbin/ldconfig ] && /sbin/ldconfig 2>/dev/null || true
}

install_deps() {
    PKG="$1"
    DEPS=$(pkg_field "$PKG" D)
    [ -n "$DEPS" ] || return 0

    for RAW in $DEPS; do
        DEP=$(normalize_dep "$RAW") || continue
        [ "$DEP" = "$PKG" ] && continue
        [ -f "$DB_DIR/$DEP" ] && continue
        if pkg_exists "$DEP"; then
            echo "[ . ] Dependency for $PKG: $DEP"
            cmd_install "$DEP"
        else
            echo "[ ! ] Dependency '$RAW' for $PKG is not a direct package, skipping"
        fi
    done
}

# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------

cmd_mirror() {
    if [ -z "$1" ] || [ "$1" = "?" ]; then
        echo "vpm mirror: $(get_mirror)"
        exit 0
    fi

    REGION=$(echo "$1" | tr '[:upper:]' '[:lower:]')
    case "$REGION" in
        global|cdn|worldwide) URL="http://dl-cdn.alpinelinux.org/alpine" ;;
        ru|russia)            URL="http://mirror.yandex.ru/mirrors/alpine" ;;
        de|germany)           URL="http://ftp.halifax.rwth-aachen.de/alpine" ;;
        us|usa)               URL="http://mirrors.edge.kernel.org/alpine" ;;
        fr|france)            URL="http://alpine.42.fr/alpine" ;;
        jp|japan)             URL="http://ftp.jaist.ac.jp/pub/Linux/alpine" ;;
        nl|netherlands)       URL="http://nl.alpinelinux.org/alpine" ;;
        *)
            echo "[ ! ] Unknown region '$1', using CDN"
            URL="https://dl-cdn.alpinelinux.org/alpine"
            ;;
    esac

    ensure_dirs
    echo "$URL" > "$CONFIG_FILE"
    echo "[ + ] Mirror set to: $URL"
    echo "[ . ] Run 'vpm update' to sync package index"
}

cmd_update() {
    ensure_dirs
    MIRROR=$(get_mirror)
    TMP_INDEX="${INDEX_FILE}.tmp"

    echo "[ . ] Syncing package index from $MIRROR ..."
    rm -f "$TMP_INDEX"

    for REPO in $REPOS; do
        URL="${MIRROR}/${ALPINE_VER}/${REPO}/${ARCH}/APKINDEX.tar.gz"
        TMP="/tmp/APKINDEX_${REPO}.tar.gz"
        echo "[ . ] Fetching $REPO..."
        if curl -sSf -o "$TMP" "$URL"; then
            tar -xOf "$TMP" APKINDEX 2>/dev/null >> "$TMP_INDEX"
            echo "" >> "$TMP_INDEX"
            rm -f "$TMP"
            echo "[ + ] $REPO OK"
        else
            echo "[ ! ] Failed to fetch $REPO index"
        fi
    done

    [ -s "$TMP_INDEX" ] || { echo "[ ! ] No indexes downloaded"; rm -f "$TMP_INDEX"; exit 1; }
    mv "$TMP_INDEX" "$INDEX_FILE"
    TOTAL=$(grep "^P:" "$INDEX_FILE" | wc -l)
    echo "[ + ] Done! $TOTAL packages available"
}

cmd_search() {
    ensure_index
    PKG="$1"
    [ -n "$PKG" ] || { echo "[ ! ] Usage: vpm search <pkg>"; exit 1; }

    echo "[ . ] Searching for '$PKG'..."
    RESULTS=$(grep "^P:.*${PKG}" "$INDEX_FILE" | sed 's/^P://')
    [ -n "$RESULTS" ] || { echo "[ ! ] No packages found matching '$PKG'"; exit 1; }

    echo "$RESULTS" | while read -r NAME; do
        VER=$(pkg_field "$NAME" V)
        DESC=$(pkg_field "$NAME" T)
        printf "  %-30s %-15s %s\n" "$NAME" "$VER" "$DESC"
    done
}

cmd_info() {
    ensure_index
    PKG="$1"
    [ -n "$PKG" ] || { echo "[ ! ] Usage: vpm info <pkg>"; exit 1; }

    VER=$(pkg_field "$PKG" V)
    [ -n "$VER" ] || { echo "[ ! ] Package '$PKG' not found"; exit 1; }

    echo "Package:      $PKG"
    echo "Version:      $VER"
    echo "Description:  $(pkg_field "$PKG" T)"
    echo "Size:         $(pkg_field "$PKG" S) bytes"
    echo "Depends:      $(pkg_field "$PKG" D)"
    if [ -f "$DB_DIR/$PKG" ]; then echo "Status:       installed"; else echo "Status:       not installed"; fi
}

cmd_install() {
    ensure_index
    PKG="$1"
    [ -n "$PKG" ] || { echo "[ ! ] Usage: vpm install <pkg>"; exit 1; }

    case " $INSTALL_STACK " in *" $PKG "*) echo "[ ! ] Dependency loop around $PKG"; return 1 ;; esac
    INSTALL_STACK="$INSTALL_STACK $PKG"
    export INSTALL_STACK

    if [ -f "$DB_DIR/$PKG" ]; then
        echo "[ . ] $PKG is already installed"
        return 0
    fi

    VER=$(pkg_field "$PKG" V)
    [ -n "$VER" ] || { echo "[ ! ] Package '$PKG' not found. Run 'vpm update' first."; exit 1; }

    ensure_dirs
    ensure_runtime_compat "$PKG"
    install_deps "$PKG"

    APK_FILE="${CACHE_DIR}/${PKG}-${VER}.apk"
    if ! download_pkg "$PKG" "$VER"; then
        echo "[ ! ] Failed to download $PKG"
        exit 1
    fi

    WORKDIR=$(make_tmpdir)
    echo "[ . ] Installing $PKG..."
    ( cd "$WORKDIR" && tar -xzf "$APK_FILE" 2>/dev/null )
    run_pkg_script "$WORKDIR/.pre-install" "$PKG" "$VER"

    if [ -f "$WORKDIR/data.tar.gz" ]; then
        tar -xzf "$WORKDIR/data.tar.gz" -C /
    else
        tar -xzf "$APK_FILE" -C / --exclude='.PKGINFO' --exclude='.pre-install' --exclude='.post-install' 2>/dev/null
    fi

    record_filelist "$APK_FILE" "$WORKDIR" "$PKG"
    echo "$VER" > "$DB_DIR/$PKG"
    run_pkg_script "$WORKDIR/.post-install" "$PKG" "$VER"
    rm -rf "$WORKDIR"

    post_install_fixes "$PKG"
    echo "[ + ] $PKG-$VER installed successfully"
}

cmd_remove() {
    PKG="$1"
    [ -n "$PKG" ] || { echo "[ ! ] Usage: vpm remove <pkg>"; exit 1; }
    [ -f "$DB_DIR/$PKG" ] || { echo "[ ! ] $PKG is not installed"; exit 1; }

    echo "[ . ] Removing files of $PKG..."
    if [ -f "$DB_DIR/$PKG.files" ]; then
        sort -r "$DB_DIR/$PKG.files" | while read -r F; do
            [ -n "$F" ] || continue
            case "$F" in /|/bin|/lib|/usr|/usr/bin|/usr/lib|/usr/share|/etc) continue ;; esac
            if [ -d "$F" ]; then rmdir "$F" 2>/dev/null || true; else rm -f "$F" 2>/dev/null; fi
        done
        rm -f "$DB_DIR/$PKG.files"
    fi

    rm -f "$DB_DIR/$PKG"
    echo "[ + ] $PKG removed"
}

cmd_list() {
    ensure_dirs
    if [ -z "$(find "$DB_DIR" -type f ! -name '*.files' 2>/dev/null | head -n 1)" ]; then
        echo "No packages installed"
        exit 0
    fi

    echo "Installed packages:"
    find "$DB_DIR" -type f ! -name '*.files' | sort | while read -r PKG_FILE; do
        PKG=$(basename "$PKG_FILE")
        VER=$(cat "$PKG_FILE")
        printf "  %-30s %s\n" "$PKG" "$VER"
    done
}

cmd_upgrade() {
    ensure_index
    ensure_dirs
    echo "[ . ] Checking for upgrades..."

    PKG_LIST=$(find "$DB_DIR" -type f ! -name '*.files' | sort)
    UPGRADED=0
    for PKG_FILE in $PKG_LIST; do
        PKG=$(basename "$PKG_FILE")
        INSTALLED_VER=$(cat "$PKG_FILE")
        REPO_VER=$(pkg_field "$PKG" V)

        if [ -n "$REPO_VER" ] && [ "$REPO_VER" != "$INSTALLED_VER" ]; then
            echo "[ . ] Upgrading $PKG: $INSTALLED_VER -> $REPO_VER"
            rm -f "$DB_DIR/$PKG"
            cmd_install "$PKG"
            UPGRADED=$((UPGRADED + 1))
        fi
    done

    if [ "$UPGRADED" -eq 0 ]; then
        echo "[ + ] All packages are up to date"
    else
        echo "[ + ] Upgraded $UPGRADED packages"
    fi
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

[ -n "$1" ] || show_help

case "$1" in
    mirror)         cmd_mirror "$2" ;;
    "mirror?")      cmd_mirror "?" ;;
    update|sync)    cmd_update ;;
    search)         cmd_search "$2" ;;
    info)           cmd_info "$2" ;;
    install)        cmd_install "$2" ;;
    remove|del|rm)  cmd_remove "$2" ;;
    list|ls)        cmd_list ;;
    upgrade)        cmd_upgrade ;;
    help|--help|-h) show_help ;;
    *)              echo "[ ! ] Unknown command: $1"; show_help ;;
esac
